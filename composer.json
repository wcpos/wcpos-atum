{
  "name": "wcpos/wcpos-atum",
  "description": "ATUM Multi-Inventory integration for WCPOS",
  "type": "wordpress-plugin",
  "license": "GPL-3.0+",
  "require": {
    "php": ">=7.4"
  },
  "require-dev": {
    "wp-phpunit/wp-phpunit": "6.9.1",
    "yoast/phpunit-polyfills": "2.0.5",
    "squizlabs/php_codesniffer": "^3.13",
    "wp-coding-standards/wpcs": "^3.3"
  },
  "scripts": {
    "lint": "phpcs --standard=./.phpcs.xml.dist",
    "lint:report": "phpcs --standard=./.phpcs.xml.dist --report=checkstyle",
    "fix": "phpcbf --standard=./.phpcs.xml.dist",
    "test": "vendor/bin/phpunit -c phpunit.xml.dist"
  },
  "config": {
    "platform": {
      "php": "7.4"
    },
    "platform-check": false,
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
